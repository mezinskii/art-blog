---
import Analytics from "@vercel/analytics/astro";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { useTranslations, type UiType } from "../i18n/utils";

type Props = {
  title: string;
  description: string;
  lang?: UiType;
  active?: string;
};

const { title, description, lang = "ru", active } = Astro.props as Props;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead lang={lang} title={title} description={description} />
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          if (stored === "night") document.documentElement.setAttribute("data-theme", "night");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header lang={lang} active={active} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <Analytics />
  </body>
</html>
