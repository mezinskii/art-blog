---
import Layout from "../../layouts/Layout.astro";

import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export async function getStaticPaths() {
  return ["en", "ru"].map((lang) => {
    return { params: { lang } };
  });
}
---

<Layout title={`${t("nav.about")} | ${t("site.title")}`} description={t("site.description")} lang={lang}>
  <div class="flex items-center flex-col mb-8">
    <h1 class="uppercase font-bold mb-8 text-4xl sm:text-6xl">{t("nav.about")}</h1>
    <ul class="text-2xl flex flex-col items-center sm:block sm:text-3xl">
      <li class="mb-2">
        <a class="no-underline" href="https://dzen.ru/ian"
          ><i class="fa-brands fa-yandex w-8"></i>&nbsp;Dzen</a>
      </li>
      <li class="mb-2" class="mb-2">
        <a class="no-underline" href="https://medium.com/@ian.mezinskii"
          ><i class="fa-brands fa-medium w-8"></i>&nbsp;Medium</a>
      </li>
      <li class="mb-2">
        <a class="no-underline" href="https://www.youtube.com/@PhilosophyIan"
          ><i class="fa-brands fa-youtube w-8"></i>&nbsp;Youtube</a>
      </li>
      <li class="mb-2">
        <a class="no-underline" href="https://www.facebook.com/share/1NXnnAy3La"
          ><i class="fa-brands fa-facebook w-8"></i>&nbsp;Facebook</a
        >
      </li>
       <li class="mb-2">
        <a class="no-underline" href="https://instagram.com/ian.mezinskii"
          ><i class="fa-brands fa-instagram w-8"></i>&nbsp;Instagram</a
        >
      </li>
    </ul>
  </div>
</Layout>
